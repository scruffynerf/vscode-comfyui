{
  "name": "vscode-comfyui",
  "displayName": "VS Code ComfyUI",
  "description": "ComfyUI rendered for your code editor",
  "version": "2.1.0",
  "publisher": "scruffynerf",
  "repository": {
    "type": "git",
    "url": "https://github.com/scruffynerf/vscode-comfyui"
  },
  "engines": {
    "vscode": "^1.96.0"
  },
  "categories": [
    "Other",
    "Visualization"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "comfyui.openReloadEditor",
        "title": "Open/Reload ComfyUI Editor",
        "category": "ComfyUI"
      },
      {
        "command": "comfyui.restartServer",
        "title": "Restart ComfyUI Server",
        "category": "ComfyUI"
      },
      {
        "command": "comfyui.installComfyUI",
        "title": "Install Hiddenswitch ComfyUI (Standard)",
        "category": "ComfyUI"
      },
      {
        "command": "comfyui.installDevelopmentComfyUI",
        "title": "Install Development ComfyUI (Git Clone)",
        "category": "ComfyUI"
      },
      {
        "command": "comfyui.runHiddenswitch",
        "title": "Run Hiddenswitch ComfyUI",
        "category": "ComfyUI"
      },
      {
        "command": "comfyui.openStateDocument",
        "title": "View Current ComfyUI State (JSON)",
        "category": "ComfyUI"
      },
      {
        "command": "comfyui.applyWorkflow",
        "title": "Apply Currently Open Workflow JSON",
        "category": "ComfyUI"
      },
      {
        "command": "comfyui.installIntegrationNode",
        "title": "Install/Update VSCode Integration Node",
        "category": "ComfyUI"
      },
      {
        "command": "comfyui.refreshNodeCatalog",
        "title": "Refresh Node Catalog",
        "category": "ComfyUI"
      }
    ],
    "configuration": {
      "title": "ComfyUI",
      "properties": {
        "comfyui.serverUrl": {
          "type": "string",
          "default": "http://localhost:8188",
          "description": "The URL of your ComfyUI instance."
        },
        "comfyui.restartEndpoint": {
          "type": "string",
          "default": "/v2/manager/reboot",
          "description": "The API endpoint used to restart the ComfyUI server."
        },
        "comfyui.installDir": {
          "type": "string",
          "default": "comfyui-workspace",
          "description": "The directory where ComfyUI will be installed."
        },
        "comfyui.installUvAutomatically": {
          "type": "boolean",
          "default": true,
          "description": "Automatically install uv if it is not found during ComfyUI installation."
        },
        "comfyui.serverTimeout": {
          "type": "number",
          "default": 60000,
          "description": "The maximum time (in milliseconds) to wait for the ComfyUI server to become responsive during startup or restart."
        },
        "comfyui.defaultBranch": {
          "type": "string",
          "default": "main",
          "description": "The default branch to checkout for development installation."
        },
        "comfyui.gitRepo": {
          "type": "string",
          "default": "https://github.com/hiddenswitch/ComfyUI.git",
          "description": "The Git repository URL to use for development ComfyUI installations."
        },
        "comfyui.venvDir": {
          "type": "string",
          "default": ".venv",
          "description": "The name of the virtual environment directory (e.g., '.venv' or 'venv')."
        },
        "comfyui.startupArgs": {
          "type": "string",
          "default": "",
          "description": "Additional startup arguments to pass to ComfyUI (e.g., '--listen 0.0.0.0 --port 8189')."
        },
        "comfyui.pythonVersion": {
          "type": "string",
          "default": "3.12",
          "description": "The Python version to use when creating the virtual environment (e.g., '3.12', '3.11', '/usr/bin/python3.12')."
        },
        "comfyui.enableAiFeatures": {
          "type": "boolean",
          "default": true,
          "description": "Enable AI agent integration: state file syncing, workflow summary, node catalog, and the apply-patch bridge. Set to false to use the extension as a plain embedded ComfyUI panel with no file-system side effects."
        }
      }
    },
    "jsonValidation": [
      {
        "fileMatch": "**/comfyai/workflow-patch.json",
        "url": "./agent-docs/comfyai/schemas/workflow-patch.schema.json"
      },
      {
        "fileMatch": "**/comfyai/apply-patch-trigger.json",
        "url": "./agent-docs/comfyai/schemas/apply-patch-trigger.schema.json"
      }
    ],
    "keybindings": [
      {
        "command": "comfyui.openReloadEditor",
        "key": "ctrl+shift+r",
        "mac": "ctrl+shift+r"
      },
      {
        "command": "comfyui.restartServer",
        "key": "ctrl+shift+alt+r",
        "mac": "ctrl+shift+alt+r"
      }
    ]
  },
  "icon": "./images/icon.png",
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/glob": "^8.1.0",
    "@types/mocha": "^10.0.1",
    "@types/node": "16.x",
    "@types/vscode": "^1.96.0",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^10.1.0",
    "glob": "^13.0.6",
    "mocha": "^11.3.0",
    "typescript": "^5.0.4"
  },
  "overrides": {
    "brace-expansion": "^2.0.1",
    "serialize-javascript": "^7.0.3",
    "minimatch": "^9.0.5"
  }
}